{
  "mcpServers": {
    "github": {
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/launch_github_mcp.ps1"
      ]
    },
    "playwright": {
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/launch_playwright_mcp.ps1"
      ],
      "tools": {
        "browser_click": { "approval_mode": "approve" },
        "browser_console_messages": { "approval_mode": "approve" },
        "browser_drag": { "approval_mode": "approve" },
        "browser_evaluate": { "approval_mode": "approve" },
        "browser_file_upload": { "approval_mode": "approve" },
        "browser_fill_form": { "approval_mode": "approve" },
        "browser_handle_dialog": { "approval_mode": "approve" },
        "browser_hover": { "approval_mode": "approve" },
        "browser_navigate": { "approval_mode": "approve" },
        "browser_navigate_back": { "approval_mode": "approve" },
        "browser_network_requests": { "approval_mode": "approve" },
        "browser_press_key": { "approval_mode": "approve" },
        "browser_resize": { "approval_mode": "approve" },
        "browser_run_code": { "approval_mode": "approve" },
        "browser_select_option": { "approval_mode": "approve" },
        "browser_snapshot": { "approval_mode": "approve" },
        "browser_tabs": { "approval_mode": "approve" },
        "browser_take_screenshot": { "approval_mode": "approve" },
        "browser_type": { "approval_mode": "approve" },
        "browser_wait_for": { "approval_mode": "approve" }
      }
    },
    "brave-search": {
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/launch_brave_mcp.ps1"
      ]
    },
    "filesystem": {
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/launch_filesystem_mcp.ps1"
      ]
    },
    "megamemory-dunderia": {
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/launch_megamemory_mcp.ps1"
      ]
    }
  }
}
